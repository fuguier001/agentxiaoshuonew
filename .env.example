# ==========================================
# 多 Agent 协作小说系统 - 环境配置模板
# ==========================================
# 复制此文件为 .env 并填写实际配置
# ==========================================

# ==========================================
# 项目配置
# ==========================================
PROJECT_NAME=我的小说
PROJECT_PATH=./projects/我的小说

# ==========================================
# 默认 LLM 提供商
# 可选：volcengine | aliyun | eggfans
# ==========================================
DEFAULT_PROVIDER=volcengine

# ==========================================
# 火山引擎配置 (OpenAI 兼容格式)
# https://console.volcengine.com/ark
# ==========================================
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=

# ==========================================
# 阿里云百炼配置
# https://bailian.console.aliyun.com/
# ==========================================
ALIYUN_API_KEY=
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_MODEL=

# ==========================================
# eggfans 配置 (自定义格式)
# ==========================================
EGGFANS_API_KEY=
EGGFANS_BASE_URL=
EGGFANS_ENDPOINT=/chat/completions
EGGFANS_MODEL=
# 自定义请求头 (可选)
EGGFANS_AUTH_TYPE=bearer
# EGGFANS_AUTH_HEADER=Authorization

# ==========================================
# 记忆引擎配置
# ==========================================
VECTOR_DB_PATH=./data/vector_db
GRAPH_DB_TYPE=networkx
SQLITE_PATH=./data/novel.db

# ==========================================
# Celery/Redis 配置
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# Web 服务配置
# ==========================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ==========================================
# Git 配置 (版本控制)
# ==========================================
AUTO_COMMIT=true
GIT_AUTHOR_NAME=Novel Agent
GIT_AUTHOR_EMAIL=novel-agent@local

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=./logs/novel-agent.log
WEBSOCKET_LOG_ENABLED=true
